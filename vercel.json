{
  "version": 2,
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "admin/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "hostess/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "pilot/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "staff/*.php": {
      "runtime": "vercel-php@0.9.0"
    },
    "user/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.php"
    }
  ]
}
